{
  "expo": {
    "name": "CE Stanby Report",
    "slug": "StanbyReportApp",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "stanby-report",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Digunakan untuk foto evidence error operasional POS.",
        "NSPhotoLibraryUsageDescription": "Digunakan untuk memilih foto evidence dari galeri."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1117",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00C2FF"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Izinkan akses foto untuk lampiran evidence.",
          "cameraPermission": "Izinkan kamera untuk foto evidence error."
        }
      ]
    ]
  }
}
